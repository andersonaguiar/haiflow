{
  "name": "Haiflow Pipeline - Kick Off Developer Agent",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "start-feature",
        "responseMode": "lastNode"
      },
      "id": "webhook-1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "notes": "POST { \"feature\": \"Add a /metrics endpoint that returns uptime and request count\" }"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:3333/trigger",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ prompt: $json.body.feature, session: 'developer', id: 'feat-' + Date.now(), source: 'n8n' }) }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Bearer YOUR_HAIFLOW_API_KEY" }
          ]
        },
        "options": {}
      },
      "id": "trigger-1",
      "name": "Trigger Developer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [480, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [[{ "node": "Trigger Developer", "type": "main", "index": 0 }]]
    }
  }
}
